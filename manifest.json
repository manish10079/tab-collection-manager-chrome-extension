{
  "manifest_version": 3,
  "name": "Tab Collection Manager",
  "version": "1.0.0",
  "description": "Auto-save and manage tab collections with premium dark mode UI",
  "permissions": [
    "tabs",
    "storage"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Collection Manager"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}